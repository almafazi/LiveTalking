APP_NAME=Aurora
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_BASE_URL=https://api.elevenlabs.io/v1

# Vast Runtime Manager (public port mapped to container :8090)
RUNTIME_MANAGER_URL=http://127.0.0.1:8090
RUNTIME_MANAGER_TOKEN=change-me
RUNTIME_MANAGER_TIMEOUT=900
# Vast LiveTalking media (public port mapped to container :8010)
# Required by infra/docker-compose.control.yml nginx /media/ proxy
RUNTIME_PUBLIC_URL=http://127.0.0.1:8010

# local | s3  (production two-machine deploy requires s3 / R2)
AVATAR_DISK=local
# Keep browser temp uploads on local disk (avoids R2 CORS on direct PUT)
LIVEWIRE_TEMPORARY_FILE_UPLOAD_DISK=local

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Local default: sqlite. Production compose uses pgsql + postgres service.
DB_CONNECTION=sqlite
# DB_HOST=postgres
# DB_PORT=5432
# DB_DATABASE=livetalking
# DB_USERNAME=livetalking
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Cloudflare R2 / S3-compatible (required when AVATAR_DISK=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=
AWS_ENDPOINT=
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=false

ADMIN_NAME=Administrator
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

VITE_APP_NAME="${APP_NAME}"
