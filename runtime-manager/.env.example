RUNTIME_MANAGER_TOKEN=change-me
RUNTIME_MANAGER_HOST=127.0.0.1
RUNTIME_MANAGER_PORT=8090
LIVETALKING_AUTOSTART=0
LIVETALKING_PYTHON=.venv/bin/python
LIVETALKING_HEALTH_URL=http://127.0.0.1:8010/api/admin/config
LIVETALKING_AUDIO_SESSION_URL=http://127.0.0.1:8010/api/audio/session
LIVETALKING_COMMAND_TEMPLATE=.venv/bin/python app.py --transport rtcpush --model {model} --avatar_id {avatar_id} --batch_size 4 --max_session 1 --push_url http://127.0.0.1:10100/rtc/v1/whip/?app=live&stream=livestream&eip=127.0.0.1
