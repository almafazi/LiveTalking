# Copy to /workspace/LiveTalking/.env.runtime and keep it outside Git.
RUNTIME_MANAGER_TOKEN='replace-with-the-same-long-random-token-used-by-laravel'
RUNTIME_MANAGER_HOST=0.0.0.0
RUNTIME_MANAGER_PORT=8090

LIVETALKING_AUTOSTART=1
LIVETALKING_PYTHON=/venv/main/bin/python
LIVETALKING_HEALTH_URL=http://127.0.0.1:8010/api/admin/config
LIVETALKING_AUDIO_SESSION_URL=http://127.0.0.1:8010/api/audio/session
LIVETALKING_COMMAND_TEMPLATE='/venv/main/bin/python app.py --transport rtcpush --model {model} --avatar_id {avatar_id} --listenport 8010 --batch_size 4 --max_session 1 --push_url http://127.0.0.1:10100/rtc/v1/whip/?app=live&stream=livestream&eip=127.0.0.1'

# Optional. deploy/vast/runtime-manager.sh fills this automatically when the
# Vast-provided PUBLIC_IPADDR and VAST_TCP_PORT_10200 variables are available.
SRS_RTC_EIP=
